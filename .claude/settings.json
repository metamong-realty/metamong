{
  "permissions": {
    "allow": [
      "Bash(echo \"${GEMINI_API_KEY:+SET}\")"
    ],
    "deny": [
      "Read(back/**/application-local.yml)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(*application-local.yml*)",
      "Bash(*.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-repository-check.sh",
            "timeout": 10,
            "statusMessage": "Repository 중복 메서드 확인 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-actions.sh",
            "timeout": 60,
            "statusMessage": "코드 품질 검사 중..."
          }
        ]
      }
    ]
  }
}
