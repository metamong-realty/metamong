{
  "description": "Metamong 프로젝트 자동화 훅 설정",
  "version": "1.0.0",
  "hooks": {
    "preToolUse": {
      "enabled": true,
      "description": "도구 사용 전 실행되는 훅",
      "rules": [
        {
          "name": "validate-kotlin-syntax",
          "description": "Kotlin 파일 작성/수정 전 문법 검증",
          "condition": {
            "tool": "Write|Edit|MultiEdit",
            "filePattern": "**/*.kt"
          },
          "action": {
            "command": "./gradlew compileKotlin",
            "workingDirectory": ".",
            "timeout": 30000
          }
        },
        {
          "name": "backup-before-major-changes",
          "description": "중요 파일 변경 전 백업 생성",
          "condition": {
            "tool": "Write|Edit|MultiEdit",
            "filePattern": "src/main/kotlin/**/*.kt|src/main/resources/application.yml"
          },
          "action": {
            "command": "git add -A && git stash push -m 'Pre-hook backup: ${FILE_PATH}'",
            "workingDirectory": ".",
            "timeout": 10000
          }
        }
      ]
    },
    "postToolUse": {
      "enabled": true,
      "description": "도구 사용 후 실행되는 훅",
      "rules": [
        {
          "name": "format-kotlin-code",
          "description": "Kotlin 파일 자동 포맷팅",
          "condition": {
            "tool": "Write|Edit|MultiEdit",
            "filePattern": "**/*.kt"
          },
          "action": {
            "command": "./gradlew ktlintFormat",
            "workingDirectory": ".",
            "timeout": 15000
          }
        },
        {
          "name": "run-quick-tests",
          "description": "빠른 테스트 실행",
          "condition": {
            "tool": "Write|Edit|MultiEdit",
            "filePattern": "src/main/kotlin/**/*.kt"
          },
          "action": {
            "command": "./gradlew test --tests='**/*Test' -x integrationTest",
            "workingDirectory": ".",
            "timeout": 60000
          }
        },
        {
          "name": "update-api-docs",
          "description": "API 문서 업데이트",
          "condition": {
            "tool": "Write|Edit|MultiEdit",
            "filePattern": "src/main/kotlin/**/controller/**/*.kt|src/main/kotlin/**/api/**/*.kt"
          },
          "action": {
            "command": "./gradlew generateSwaggerDocs",
            "workingDirectory": ".",
            "timeout": 20000
          }
        },
        {
          "name": "validate-database-migration",
          "description": "데이터베이스 마이그레이션 검증",
          "condition": {
            "tool": "Write",
            "filePattern": "src/main/resources/db/migration/*.sql"
          },
          "action": {
            "command": "./gradlew flywayValidate",
            "workingDirectory": ".",
            "timeout": 30000
          }
        }
      ]
    },
    "sessionStart": {
      "enabled": true,
      "description": "Claude Code 세션 시작 시 실행",
      "rules": [
        {
          "name": "update-dependencies",
          "description": "의존성 업데이트 확인",
          "condition": {
            "frequency": "daily"
          },
          "action": {
            "command": "./gradlew dependencyUpdates",
            "workingDirectory": ".",
            "timeout": 30000
          }
        },
        {
          "name": "cleanup-logs",
          "description": "로그 파일 정리",
          "condition": {
            "frequency": "session"
          },
          "action": {
            "command": "find logs -name '*.log' -mtime +7 -delete",
            "workingDirectory": ".",
            "timeout": 5000
          }
        },
        {
          "name": "security-scan",
          "description": "보안 스캔 실행",
          "condition": {
            "frequency": "weekly"
          },
          "action": {
            "command": "./gradlew dependencyCheckAnalyze",
            "workingDirectory": ".",
            "timeout": 120000
          }
        }
      ]
    },
    "sessionEnd": {
      "enabled": true,
      "description": "Claude Code 세션 종료 시 실행",
      "rules": [
        {
          "name": "generate-coverage-report",
          "description": "테스트 커버리지 보고서 생성",
          "condition": {
            "hasChanges": true,
            "filePattern": "src/main/kotlin/**/*.kt"
          },
          "action": {
            "command": "./gradlew jacocoTestReport",
            "workingDirectory": ".",
            "timeout": 60000
          }
        },
        {
          "name": "commit-staged-changes",
          "description": "스테이징된 변경사항 커밋",
          "condition": {
            "hasStaged": true,
            "interactive": true
          },
          "action": {
            "command": "git commit -m 'feat: auto-commit from Claude Code session\n\n🤖 Generated with Claude Code\n\nCo-Authored-By: Claude <noreply@anthropic.com>'",
            "workingDirectory": ".",
            "timeout": 10000
          }
        }
      ]
    },
    "errorHandler": {
      "enabled": true,
      "description": "오류 발생 시 실행되는 훅",
      "rules": [
        {
          "name": "compile-error-recovery",
          "description": "컴파일 오류 시 복구 시도",
          "condition": {
            "errorType": "compilation",
            "tool": "Write|Edit|MultiEdit"
          },
          "action": {
            "command": "./gradlew clean compileKotlin --info",
            "workingDirectory": ".",
            "timeout": 45000
          }
        },
        {
          "name": "test-failure-analysis",
          "description": "테스트 실패 시 분석",
          "condition": {
            "errorType": "test-failure"
          },
          "action": {
            "command": "./gradlew test --rerun-tasks --info",
            "workingDirectory": ".",
            "timeout": 90000
          }
        },
        {
          "name": "restore-backup",
          "description": "심각한 오류 시 백업 복구",
          "condition": {
            "errorType": "critical",
            "interactive": true
          },
          "action": {
            "command": "git stash pop",
            "workingDirectory": ".",
            "timeout": 5000
          }
        }
      ]
    }
  },
  "settings": {
    "timeout": {
      "default": 30000,
      "maximum": 300000
    },
    "retries": {
      "enabled": true,
      "maxRetries": 2,
      "retryDelay": 5000
    },
    "notifications": {
      "enabled": true,
      "verbosity": "normal",
      "showSuccess": false,
      "showErrors": true,
      "showWarnings": true
    },
    "environment": {
      "inheritParent": true,
      "variables": {
        "GRADLE_OPTS": "-Xmx2g",
        "JAVA_HOME": "${env.JAVA_HOME}",
        "CI": "false"
      }
    },
    "parallelExecution": {
      "enabled": false,
      "maxConcurrency": 2
    }
  },
  "profiles": {
    "development": {
      "description": "개발 환경용 프로필",
      "enabled": true,
      "hooks": {
        "preToolUse": ["validate-kotlin-syntax"],
        "postToolUse": ["format-kotlin-code", "run-quick-tests"],
        "sessionStart": ["cleanup-logs"],
        "sessionEnd": ["generate-coverage-report"]
      }
    },
    "production": {
      "description": "프로덕션 배포용 프로필",
      "enabled": false,
      "hooks": {
        "preToolUse": ["validate-kotlin-syntax", "backup-before-major-changes"],
        "postToolUse": ["format-kotlin-code", "run-quick-tests", "update-api-docs"],
        "sessionStart": ["update-dependencies", "security-scan"],
        "sessionEnd": ["generate-coverage-report", "commit-staged-changes"]
      }
    },
    "testing": {
      "description": "테스트 중심 프로필",
      "enabled": false,
      "hooks": {
        "preToolUse": ["validate-kotlin-syntax"],
        "postToolUse": ["format-kotlin-code", "run-quick-tests"],
        "sessionStart": ["cleanup-logs"],
        "sessionEnd": ["generate-coverage-report"]
      },
      "settings": {
        "timeout": {
          "default": 60000
        }
      }
    }
  },
  "integrations": {
    "git": {
      "enabled": true,
      "autoStage": false,
      "autoCommit": false,
      "branchProtection": {
        "enabled": true,
        "protectedBranches": ["main", "master", "develop"]
      }
    },
    "gradle": {
      "enabled": true,
      "daemon": true,
      "parallel": true,
      "buildCache": true
    },
    "ide": {
      "enabled": true,
      "refreshProject": true,
      "syncSettings": true
    },
    "docker": {
      "enabled": false,
      "autoRebuild": false
    }
  }
}